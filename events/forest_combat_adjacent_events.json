          { "type": "add_tag", "tag": "found_raid_aftermath" }
        ],
        "next_event": null
      },
      {
        "id": "ignore",
        "text": "Ignore it and stay on course",
        "effects": [],
        "next_event": null
      },
      {
        "id": "approach_carefully",
        "text": "Approach carefully—survivors might still be there",
        "effects": [
          { "type": "advance_time", "amount": 1 },
          { "type": "reveal_secrets" },
          { "type": "add_tag", "tag": "found_raid_aftermath" }
        ],
        "next_event": null
      }
    ]
  },
  {
    "id": "forest_night_watch",
    "title": "The Night Watch",
    "biomes": ["forest"],
    "weight": 10,
    "one_shot": false,
    "text": "You make camp and set a watch. Around the third hour, the watcher hears something moving just outside the fire's light. Not approaching. Not leaving. Circling. For hours.",
    "choices": [
      {
        "id": "wake_party",
        "text": "Wake the party—everyone up, weapons ready",
        "effects": [
          { "type": "add_tag", "tag": "night_watch_alert" },
          { "type": "change_stat", "stat": "hp", "amount": -3 }
        ],
        "next_event": null
      },
      {
        "id": "let_it_pass",
        "text": "Watch and wait. Don't provoke it.",
        "effects": [
          { "type": "add_tag", "tag": "night_stalker_observed" },
          { "type": "advance_time", "amount": 1 }
        ],
        "next_event": null
      },
      {
        "id": "send_someone_out",
        "text": "Send someone into the dark to look",
        "effects": [
          { "type": "start_combat", "encounter_id": "beasts/warg_scouts" }
        ],
        "next_event": null
      }
    ]
  },
  {
    "id": "forest_wounded_goblin",
    "title": "The Wounded Goblin",
    "biomes": ["forest"],
    "weight": 8,
    "one_shot": false,
    "text": "A single goblin—small even by goblin standards, probably not yet an adult—sits alone at the base of a tree with a wound it cannot reach. It sees you and goes completely still. Terrified. Not attacking.",
    "choices": [
      {
        "id": "let_it_go",
        "text": "Leave it alone. Let it go.",
        "effects": [
          { "type": "add_tag", "tag": "goblin_child_spared" }
        ],
        "next_event": null
      },
      {
        "id": "capture_it",
        "text": "Capture it—get information about nearby movements",
        "effects": [
          { "type": "reveal_secrets" },
          { "type": "add_tag", "tag": "goblin_captive_info" },
          { "type": "advance_time", "amount": 1 }
        ],
        "next_event": null
      },
      {
        "id": "threaten_for_info",
        "text": "Threaten it. It tells you everything immediately and runs.",
        "effects": [
          { "type": "reveal_secrets" },
          { "type": "add_tag", "tag": "goblin_child_threatened" }
        ],
        "next_event": null
      },
      {
        "id": "kill_it",
        "text": "Kill it",
        "effects": [
          { "type": "add_tag", "tag": "dark_deeds" }
        ],
        "next_event": null
      }
    ]
  },
  {
    "id": "forest_cart_robbery",
