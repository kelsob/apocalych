[
  {
    "id": "forest_ambush_signs",
    "title": "The Ambush Signs",
    "biomes": ["forest"],
    "weight": 10,
    "one_shot": false,
    "text": "You notice it before you should have—disturbed earth beside the path, a rope end with a fresh cut, the smell of nervous men trying to be quiet. Something is waiting ahead. It doesn't know that you know.",
    "choices": [
      {
        "id": "prepare_for_it",
        "text": "Prepare—weapons ready, positions set, let them come",
        "effects": [
          { "type": "add_tag", "tag": "ambush_prepared" },
          { "type": "start_combat", "encounter_id": "bandit_ambush" }
        ],
        "next_event": null
      },
      {
        "id": "sneak_around",
        "text": "Find a way around without triggering it",
        "effects": [
          { "type": "advance_time", "amount": 1 },
          { "type": "add_tag", "tag": "avoided_ambush" }
        ],
        "next_event": null
      },
      {
        "id": "loud_approach",
        "text": "Walk in loudly and obviously—make it clear you're not worth the trouble",
        "effects": [
          { "type": "add_tag", "tag": "bluffed_ambush" }
        ],
        "next_event": null
      },
      {
        "id": "counter_ambush",
        "text": "Set your own positions and become the ambushers",
        "effects": [
          { "type": "add_tag", "tag": "counter_ambush" },
          { "type": "start_combat", "encounter_id": "humans/bandit_gang" }
        ],
        "next_event": null
      }
    ]
  },
  {
    "id": "forest_standoff",
    "title": "The Standoff",
    "biomes": ["forest"],
    "weight": 9,
    "one_shot": false,
    "text": "Two groups face each other across a clearing—militia on one side, bandits on the other. Swords out, nobody moving. This has been going on for a while. They both look at you when you step into view, as if you might be the thing that decides it.",
    "choices": [
      {
        "id": "back_militia",
        "text": "Back the militia",
        "effects": [
          { "type": "start_combat", "encounter_id": "humans/bandit_crew" },
          { "type": "change_reputation", "faction": "militia", "amount": 10 }
        ],
        "next_event": null
      },
      {
        "id": "back_bandits",
        "text": "Back the bandits—the militia started it, clearly",
        "effects": [
          { "type": "start_combat", "encounter_id": "humans/militia_patrol" },
          { "type": "change_reputation", "faction": "militia", "amount": -20 },
          { "type": "add_tag", "tag": "dark_deeds" }
        ],
        "next_event": null
      },
      {
        "id": "broker_peace",
        "text": "Step between them and try to end it peacefully",
        "effects": [
          { "type": "add_tag", "tag": "standoff_resolved" },
          { "type": "change_reputation", "faction": "militia", "amount": 5 },
          { "type": "change_reputation", "faction": "locals", "amount": 5 }
        ],
        "next_event": null
      },
      {
        "id": "watch_from_cover",
        "text": "Stay hidden and watch. One side wins. You deal with the victor.",
        "effects": [
          { "type": "advance_time", "amount": 2 },
          { "type": "add_tag", "tag": "watched_standoff" }
        ],
        "next_event": null
      },
      {
        "id": "rob_both",
        "text": "Rob both sides while they're focused on each other",
        "effects": [
          { "type": "give_gold", "amount": 25 },
          { "type": "add_tag", "tag": "dark_deeds" },
          { "type": "change_reputation", "faction": "militia", "amount": -10 }
        ],
        "next_event": null
      }
    ]
  },
  {
    "id": "forest_trapped_warg",
    "title": "Trapped Beast",
    "biomes": ["forest"],
    "weight": 8,
    "one_shot": false,
    "text": "A large warg has its rear leg caught in a hunter's snare, the wire cutting deep into the flesh. It snarls when you approach—exhausted and in pain, fighting something it cannot beat.",
    "choices": [
      {
        "id": "free_it",
        "text": "Cut it loose",
        "effects": [
          { "type": "change_stat", "stat": "hp", "amount": -5 },
          { "type": "add_tag", "tag": "freed_warg" }
        ],
        "next_event": null
      },
      {
        "id": "mercy_kill",
        "text": "End its suffering cleanly",
        "effects": [
          { "type": "add_tag", "tag": "mercy_killed_warg" }
        ],
        "next_event": null
      },
      {
        "id": "leave_it",
        "text": "Leave it. Nature decides.",
        "effects": [],
        "next_event": null
      },
      {
        "id": "study_trap",
        "text": "Study the trap—this tells you who's hunting here",
        "effects": [
          { "type": "reveal_secrets" },
          { "type": "add_tag", "tag": "knows_trap_maker" }
        ],
        "next_event": null
      }
    ]
  },
  {
    "id": "forest_warning_sign",
    "title": "The Warning",
    "biomes": ["forest"],
    "weight": 9,
    "one_shot": false,
    "text": "Someone has nailed a board to a tree: \"TURN BACK — THERE ARE THINGS IN THESE WOODS THAT SHOULD NOT BE.\" Old sign. Whoever wrote it is long gone. Beneath it, in fresh charcoal: \"Still true.\"",
    "choices": [
      {
        "id": "heed_warning",
        "text": "Take the longer safe path",
        "effects": [
          { "type": "advance_time", "amount": 2 }
        ],
        "next_event": null
      },
      {
        "id": "push_on",
        "text": "Push on regardless",
        "effects": [
          { "type": "add_tag", "tag": "ignored_warning" },
          { "type": "start_combat", "encounter_id": "mixed/tainted_forest" }
        ],
        "next_event": null
      },
      {
        "id": "investigate_warning",
        "text": "Find who wrote the fresh note—they're still nearby",
        "effects": [
          { "type": "reveal_secrets" },
          { "type": "add_tag", "tag": "investigated_warning" }
        ],
        "next_event": null
      }
    ]
  },
  {
    "id": "forest_smoke_on_wind",
    "title": "Smoke on the Wind",
    "biomes": ["forest"],
    "weight": 11,
    "one_shot": false,
    "text": "Black smoke to the north. Too thick, too dark, the wrong smell for a campfire. Could be a farmstead. Could be something worse.",
    "choices": [
      {
        "id": "investigate",
        "text": "Investigate",
        "effects": [
