        ],
        "next_event": null
      },
      {
        "id": "negotiate",
        "text": "Step in and talk the bandits into taking less and leaving",
        "effects": [
          { "type": "add_tag", "tag": "negotiated_robbery" },
          { "type": "give_gold", "amount": 10 },
          { "type": "change_reputation", "faction": "locals", "amount": 8 }
        ],
        "next_event": null
      },
      {
        "id": "wait_and_collect",
        "text": "Wait for it to resolve. The merchant pays you to stay out of it.",
        "effects": [
          { "type": "give_gold", "amount": 8 },
          { "type": "add_tag", "tag": "let_robbery_happen" }
        ],
        "next_event": null
      },
      {
        "id": "join_bandits",
        "text": "Join the bandits",
        "effects": [
          { "type": "give_gold", "amount": 30 },
          { "type": "change_reputation", "faction": "locals", "amount": -25 },
          { "type": "add_tag", "tag": "dark_deeds" }
        ],
        "next_event": null
      }
    ]
  },
