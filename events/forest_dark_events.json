  {
    "id": "forest_wanted_man",
    "title": "The Wanted Man",
    "biomes": ["forest"],
    "weight": 7,
    "one_shot": false,
    "text": "A well-dressed man runs out of the trees, panting, and grabs your arm. \"Please. You've got to hide me. They're right behind me.\" Three militia soldiers appear around the bend thirty seconds later, hands on their weapons. Everyone waits for you to decide.",
    "choices": [
      {
        "id": "hide_him",
        "text": "Step in front of him. \"Haven't seen anyone.\"",
        "effects": [
          { "type": "change_reputation", "faction": "militia", "amount": -15 },
          { "type": "add_tag", "tag": "sheltered_fugitive" }
        ],
        "next_event": null
      },
      {
        "id": "hand_him_over",
        "text": "Step aside. \"He came from the east.\"",
        "effects": [
          { "type": "give_gold", "amount": 20 },
          { "type": "change_reputation", "faction": "militia", "amount": 10 },
          { "type": "add_tag", "tag": "turned_in_fugitive" }
        ],
        "next_event": null
      },
      {
        "id": "refuse_to_engage",
        "text": "Hold up your hands. \"This has nothing to do with us.\" Walk away.",
        "effects": [
          { "type": "advance_time", "amount": 1 }
        ],
        "next_event": null
      }
    ]
  },
