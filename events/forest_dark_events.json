[
  {
    "id": "forest_burning_farmstead",
    "title": "Burning Farmstead",
    "biomes": ["forest"],
    "weight": 7,
    "one_shot": false,
    "text": "Smoke first. Then the smell of burning thatch. You round a bend and find a farmstead fully ablaze. A figure runs toward you from the yard—screaming—and behind them, small green shapes loot what the fire hasn't taken.",
