      {
        "id": "attack_now",
        "text": "Attack now—surprise advantage and momentum",
        "effects": [
          { "type": "add_tag", "tag": "ambush_prepared" },
          { "type": "start_combat", "encounter_id": "fel/goblin_warband" }
        ],
        "next_event": null
      },
      {
        "id": "sneak_past",
        "text": "Sneak past their perimeter using the ridge",
        "effects": [
          { "type": "advance_time", "amount": 2 },
          { "type": "add_tag", "tag": "slipped_past_goblin_camp" }
