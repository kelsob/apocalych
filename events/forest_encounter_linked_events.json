          { "type": "start_combat", "encounter_id": "fel/bone_cavalry" }
        ],
        "next_event": null
      },
      {
        "id": "set_a_trap",
        "text": "Set a trap and let them come to you",
        "effects": [
          { "type": "advance_time", "amount": 1 },
          { "type": "start_combat", "encounter_id": "fel/bone_cavalry" }
        ],
        "next_event": null
      },
      {
        "id": "evacuate_the_area",
        "text": "Get out of the area entirely",
        "effects": [
          { "type": "advance_time", "amount": 2 }
        ],
        "next_event": null
      }
    ]
  },
  {
    "id": "forest_elven_ambush_warning",
    "title": "The Elven Ambush Warning",
    "biomes": ["forest"],
    "weight": 8,
    "one_shot": false,
    "text": "An arrow lands point-first between your feet. Attached to the shaft: a single leaf with one word scratched into it in elvish. A passing trader translates when you show them: \"Leave.\"",
    "choices": [
      {
        "id": "leave",
        "text": "Leave. The message is clear.",
        "effects": [
          { "type": "advance_time", "amount": 2 },
          { "type": "change_reputation", "faction": "elves", "amount": 5 }
        ],
        "next_event": null
      },
      {
        "id": "find_them_and_parlay",
        "text": "Find whoever shot it and attempt to negotiate",
        "effects": [
          { "type": "advance_time", "amount": 1 },
          { "type": "reveal_secrets" },
          { "type": "add_tag", "tag": "elven_parley_attempted" }
        ],
        "next_event": null
      },
      {
        "id": "keep_walking",
        "text": "Keep walking. You got the message.",
        "effects": [
          { "type": "start_combat", "encounter_id": "elves/elven_ambush" },
          { "type": "change_reputation", "faction": "elves", "amount": -15 }
        ],
        "next_event": null
      }
    ]
  },
  {
