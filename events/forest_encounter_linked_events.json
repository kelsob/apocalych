  {
    "id": "forest_drake_roost",
    "title": "The Drake's Roost",
    "biomes": ["forest"],
    "weight": 7,
    "one_shot": false,
    "text": "Scorched trees. Deep claw marks in the stone of a cliff face. Bones from kills dragged here over months. Something very large roosts nearby, and you're close enough to its territory that this is going to require a decision.",
    "choices": [
      {
        "id": "avoid_territory",
        "text": "Avoid its territory—take the wide path around",
        "effects": [
          { "type": "advance_time", "amount": 2 }
        ],
        "next_event": null
      },
      {
        "id": "drive_it_out",
        "text": "Drive it out of the area",
        "effects": [
          { "type": "start_combat", "encounter_id": "beasts/drake_ambush" }
        ],
        "next_event": null
      },
      {
        "id": "leave_offering",
        "text": "Leave a meat offering at the edge of its territory—old practice",
        "effects": [
          { "type": "give_item", "item_id": "meat", "count": -1 },
          { "type": "add_tag", "tag": "paid_respects" }
        ],
        "next_event": null
      },
      {
        "id": "steal_from_hoard",
        "text": "Find the hoard while it's out and take what you can",
        "effects": [
          { "type": "give_gold", "amount": 40 },
          { "type": "give_item", "item_id": "trinket", "count": 2 },
          { "type": "start_combat", "encounter_id": "beasts/drake_ambush" },
          { "type": "add_tag", "tag": "robbed_drake_hoard" }
        ],
        "next_event": null
      }
    ]
  },
  {
    "id": "forest_bone_warg_mark",
