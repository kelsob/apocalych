  {
    "id": "forest_false_merchant",
    "title": "The Merchant's Call for Help",
    "biomes": ["forest"],
    "weight": 9,
    "one_shot": false,
    "text": "A voice from the treeline: \"Please! They took everything! Help me!\" It sounds genuinely desperate. It's also exactly what you'd say if you needed someone to walk into an ambush.",
    "choices": [
      {
        "id": "rush_in",
        "text": "Rush in to help",
        "effects": [
          { "type": "start_combat", "encounter_id": "humans/bandit_gang" },
          { "type": "change_stat", "stat": "hp", "amount": -5 }
        ],
        "next_event": null
      },
      {
        "id": "approach_cautiously",
        "text": "Approach carefully—spot the ambush before they spring it",
        "effects": [
          { "type": "add_tag", "tag": "ambush_prepared" },
          { "type": "start_combat", "encounter_id": "humans/bandit_gang" }
        ],
        "next_event": null
      },
      {
        "id": "call_their_bluff",
        "text": "Call out loudly that you see them and you're armed",
        "effects": [
          { "type": "add_tag", "tag": "bluffed_ambush" }
        ],
        "next_event": null
      }
    ]
  },
  {
