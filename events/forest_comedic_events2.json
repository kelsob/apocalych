  {
    "id": "forest_mushroom_picker",
    "title": "The Competitive Mushroom Picker",
    "biomes": ["forest"],
    "weight": 10,
    "one_shot": false,
    "text": "An absolutely furious hobbit woman who has been picking mushrooms at this precise spot for forty years is standing in your way, and you are in her way, and she would like you to know that this is unacceptable.",
    "choices": [
      {
        "id": "apologize_and_leave",
        "text": "Apologize sincerely and step aside",
        "effects": [
          { "type": "give_item", "item_id": "mushroom", "count": 3 },
          { "type": "change_reputation", "faction": "hobbits", "amount": 3 }
        ],
        "next_event": null
      },
      {
        "id": "help_her_pick",
        "text": "Offer to help her pick—she warms up eventually",
        "effects": [
          { "type": "advance_time", "amount": 1 },
          { "type": "give_item", "item_id": "mushroom", "count": 5 },
          { "type": "change_reputation", "faction": "hobbits", "amount": 8 }
        ],
        "next_event": null
      },
      {
        "id": "argue_with_her",
        "text": "Argue with her about whose road this is",
        "effects": [
          { "type": "advance_time", "amount": 1 },
          { "type": "change_reputation", "faction": "hobbits", "amount": -5 }
        ],
        "next_event": null
      },
      {
        "id": "try_to_outpick_her",
        "text": "Challenge her—outpick her and prove your worth",
        "effects": [
          { "type": "advance_time", "amount": 1 },
          { "type": "give_item", "item_id": "mushroom", "count": 2 },
          { "type": "add_tag", "tag": "lost_mushroom_contest" }
        ],
        "next_event": null
      }
    ]
  },
  {
    "id": "forest_bet_event",
    "title": "The Bet",
    "biomes": ["forest"],
    "weight": 10,
    "one_shot": false,
    "text": "A small group of humans are wagering on something. A snail race. Two snails on a log, taken very seriously. Money has changed hands. They invite you enthusiastically to participate.",
    "choices": [
      {
        "id": "bet_gold",
        "text": "Bet gold on the faster-looking one",
        "effects": [
          { "type": "pay_gold", "amount": 10 },
          { "type": "give_gold", "amount": 20 }
        ],
        "next_event": null
      },
      {
        "id": "join_for_fun",
        "text": "Watch and cheer. Join for the fun of it.",
        "effects": [
          { "type": "add_tag", "tag": "good_morale" },
          { "type": "advance_time", "amount": 1 }
        ],
        "next_event": null
      },
      {
        "id": "cheat",
        "text": "Subtly interfere with one of the snails",
        "effects": [
          { "type": "give_gold", "amount": 15 },
          { "type": "add_tag", "tag": "cheated_at_snails" }
        ],
        "next_event": null
      },
      {
        "id": "decline_politely",
        "text": "Decline politely and move on",
        "effects": [],
        "next_event": null
      }
    ]
  },
  {
    "id": "forest_cook_off",
    "title": "The Cook-Off",
    "biomes": ["forest"],
    "weight": 9,
    "one_shot": false,
    "text": "The caravan cook has challenged your party to produce a better meal than him by morning. He is extremely confident. He is also, you notice, an excellent cook. This is going to be difficult.",
    "choices": [
      {
        "id": "accept_the_challenge",
        "text": "Accept. You'll figure out something.",
        "effects": [
          { "type": "advance_time", "amount": 1 },
          { "type": "give_item", "item_id": "ration", "count": 3 },
          { "type": "add_tag", "tag": "good_morale" }
        ],
        "next_event": null
      },
      {
        "id": "decline_gracefully",
        "text": "Decline gracefully—he makes you something anyway and it's excellent",
        "effects": [
          { "type": "change_stat", "stat": "hp", "amount": 10 },
          { "type": "add_tag", "tag": "good_morale" }
        ],
        "next_event": null
      },
      {
        "id": "cheat_magically",
        "text": "Use a magical shortcut",
        "condition": {
          "requires_any": ["has_mage", "herb_witch_favor"]
        },
        "effects": [
          { "type": "give_gold", "amount": 10 },
          { "type": "give_item", "item_id": "ration", "count": 5 },
          { "type": "add_tag", "tag": "good_morale" }
        ],
        "next_event": null
      }
    ]
  },
  {
