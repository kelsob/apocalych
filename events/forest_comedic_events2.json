[
  {
    "id": "forest_enthusiastic_dog",
    "title": "The Very Enthusiastic Dog",
    "biomes": ["forest"],
    "weight": 13,
    "one_shot": false,
    "text": "A dog with no owner appears from nowhere and wants to play fetch RIGHT NOW. It has found a stick. It has dropped the stick at your feet. It is looking at you with a level of hope that is genuinely difficult to disappoint.",
    "choices": [
      {
        "id": "play_fetch",
        "text": "Play fetch with it",
        "effects": [
          { "type": "add_tag", "tag": "good_morale" },
          { "type": "advance_time", "amount": 1 }
        ],
        "next_event": null
      },
      {
        "id": "find_its_owner",
        "text": "Try to find its owner—it must belong to someone",
        "effects": [
          { "type": "advance_time", "amount": 1 },
          { "type": "reveal_secrets" },
          { "type": "add_tag", "tag": "found_dog_owner" }
        ],
        "next_event": null
      },
      {
        "id": "adopt_it",
        "text": "Adopt it. You have a dog now.",
        "effects": [
          { "type": "add_tag", "tag": "has_dog_companion" },
          { "type": "add_tag", "tag": "good_morale" }
        ],
        "next_event": null
      },
      {
        "id": "ignore_it",
        "text": "Walk past ignoring it completely",
        "effects": [
          { "type": "add_tag", "tag": "dog_follows_anyway" }
        ],
        "next_event": null
      }
    ]
  },
  {
