[
  {
    "id": "forest_unnatural_silence",
    "title": "Unnatural Silence",
    "biomes": ["forest"],
    "weight": 9,
    "one_shot": false,
    "text": "The birds stop. The insects stop. Even the wind seems to hold its breath. The forest is completely silent—the kind of silence that takes effort to produce. Then, from somewhere deeper in the trees: a low, rhythmic thudding. Steady. Patient.",
    "choices": [
      {
        "id": "investigate",
        "text": "Move toward the sound",
        "effects": [
          { "type": "start_combat", "encounter_id": "mixed/tainted_forest" },
          { "type": "add_tag", "tag": "witnessed_corruption" }
        ],
        "next_event": null
      },
      {
        "id": "wait_and_watch",
        "text": "Wait and observe from cover",
        "effects": [
          { "type": "add_tag", "tag": "corruption_warning" },
          { "type": "reveal_secrets" }
        ],
        "next_event": null
      },
      {
        "id": "get_out",
        "text": "Get out of here. Now.",
        "effects": [
          { "type": "advance_time", "amount": 1 }
        ],
        "next_event": null
      }
    ]
  },
  {
    "id": "forest_standing_stones",
    "title": "Standing Stones",
    "biomes": ["forest"],
    "weight": 7,
    "one_shot": true,
    "text": "A ring of eight stones stands in a clearing—each about knee height, each carved with symbols you don't recognize. The grass inside the ring is perfectly flat and a subtly different shade of green. No wind disturbs it.",
