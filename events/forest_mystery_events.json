  {
    "id": "forest_cursed_grove",
    "title": "The Cursed Grove",
    "biomes": ["forest"],
    "weight": 6,
    "one_shot": true,
    "text": "The trees in this section of the forest are wrong. Their bark is gray-black. Their branches grow at unnatural angles. There are no dead leaves on the ground—nothing rots here. At the center of the grove, the largest tree pulses with a dull, dark light.",
    "choices": [
      {
        "id": "approach_tree",
        "text": "Approach the pulsing tree",
        "effects": [
          { "type": "start_combat", "encounter_id": "beasts/cursed_grove" },
          { "type": "add_tag", "tag": "witnessed_corruption" }
        ],
        "next_event": null
